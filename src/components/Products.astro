							<span class="star active">★</span>
							<span class="star active">★</span>
							<span class="star active">★</span>
							<span class="star active">★</span>
							<span class="star active">★</span>
						</div>
						<span class="rating-text">(41 reviews)</span>
					</div>
				</div>
			</div>
			
			<div class="product-card" data-category="traditional">
				<div class="product-image">
					<img src="https://images.pexels.com/photos/8839888/pexels-photo-8839888.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Colorful Mojari" />
					<div class="product-overlay">
						<button class="quick-view-btn">Quick View</button>
					</div>
					<div class="product-badge bestseller">Bestseller</div>
				</div>
				<div class="product-info">
					<h3 class="product-name">Carnival Mojari</h3>
					<p class="product-description">Dazzling mojari with rainbow embroidery and luxurious velvet in bold colors.</p>
					<div class="product-price">
						<span class="current-price">PKR 3,800</span>
					</div>
					<div class="product-rating">
						<div class="stars">
							<span class="star active">★</span>
							<span class="star active">★</span>
							<span class="star active">★</span>
