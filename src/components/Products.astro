<section id="products" class="products section">
	<div class="container">
		<div class="section-header">
			<div class="section-badge">
				<span>Vibrant Collection</span>
			</div>
			<h2 class="section-title">Bold & Colorful Designs</h2>
			<p class="section-description">
				Explore our stunning collection of vibrant footwear that combines traditional Pakistani 
				craftsmanship with bold, contemporary colors and eye-catching designs.
			</p>
		</div>
		
		<div class="product-categories">
			<button class="category-btn active" data-category="all">All Products</button>
			<button class="category-btn" data-category="formal">Formal</button>
			<button class="category-btn" data-category="casual">Casual</button>
			<button class="category-btn" data-category="traditional">Traditional</button>
		</div>
		
		<div class="products-grid">
			<div class="product-card" data-category="formal">
				<div class="product-image">
					<img src="https://images.pexels.com/photos/1598505/pexels-photo-1598505.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Vibrant Formal Shoes" />
					<div class="product-overlay">
						<button class="quick-view-btn">Quick View</button>
					</div>
					<div class="product-badge">New</div>
				</div>
				<div class="product-info">
					<h3 class="product-name">Vibrant Executive</h3>
					<p class="product-description">Bold colored formal shoes that make a statement in any professional setting.</p>
					<div class="product-price">
						<span class="current-price">PKR 8,500</span>
						<span class="original-price">PKR 10,000</span>
					</div>
					<div class="product-rating">
						<div class="stars">
							<span class="star active">★</span>
							<span class="star active">★</span>
							<span class="star active">★</span>
							<span class="star active">★</span>
							<span class="star active">★</span>
						</div>
						<span class="rating-text">(48 reviews)</span>
					</div>
				</div>
			</div>
			
			<div class="product-card" data-category="casual">
