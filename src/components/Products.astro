					<div class="product-overlay">
						<button class="quick-view-btn">Quick View</button>
					</div>
					<div class="product-badge bestseller">Bestseller</div>
				</div>
				<div class="product-info">
					<h3 class="product-name">Rainbow Comfort</h3>
					<p class="product-description">Vibrant multi-colored casual shoes that bring joy to every step.</p>
					<div class="product-price">
						<span class="current-price">PKR 6,500</span>
					</div>
					<div class="product-rating">
						<div class="stars">
							<span class="star active">★</span>
							<span class="star active">★</span>
							<span class="star active">★</span>
							<span class="star active">★</span>
							<span class="star">★</span>
						</div>
						<span class="rating-text">(32 reviews)</span>
					</div>
				</div>
			</div>
			
			<div class="product-card" data-category="traditional">
				<div class="product-image">
					<img src="https://images.pexels.com/photos/8839887/pexels-photo-8839887.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Colorful Traditional Shoes" />
					<div class="product-overlay">
						<button class="quick-view-btn">Quick View</button>
