<style>
	.footer {
		background: linear-gradient(135deg, var(--color-neutral-800) 0%, var(--color-neutral-900) 100%);
		color: white;
		padding: var(--spacing-20) 0 0;
	}

	.footer-content {
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: var(--spacing-16);
		margin-bottom: var(--spacing-16);
	}

	.footer-brand {
		max-width: 400px;
	}

	.brand-logo {
		display: flex;
		align-items: center;
		margin-bottom: var(--spacing-4);
	}

	.brand-text {
		font-family: var(--font-display);
		font-size: 2rem;
		font-weight: 600;
		color: white;
		background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		letter-spacing: -0.02em;
	}

	.brand-description {
		color: var(--color-neutral-300);
		line-height: 1.7;
		margin-bottom: var(--spacing-6);
	}

	.social-links {
		display: flex;
		gap: var(--spacing-4);
	}

	.social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		background: rgba(255, 255, 255, 0.1);
		color: var(--color-neutral-300);
		border-radius: 12px;
		text-decoration: none;
		transition: all 0.3s ease;
		backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.social-link:hover {
		background: var(--color-primary);
		color: white;
		transform: translateY(-2px);
		box-shadow: var(--shadow-lg);
	}

	.footer-links {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-8);
	}

	.link-group {
		display: flex;
		flex-direction: column;
	}

	.link-title {
		font-size: 1.125rem;
		font-weight: 600;
		color: white;
		margin-bottom: var(--spacing-4);
	}

	.link-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.footer-link {
		color: var(--color-neutral-300);
		text-decoration: none;
		transition: all 0.3s ease;
		position: relative;
		padding-left: var(--spacing-4);
	}

	.footer-link::before {
		content: '';
		position: absolute;
		left: 0;
		top: 50%;
		transform: translateY(-50%);
		width: 4px;
		height: 4px;
		background: var(--color-primary);
		border-radius: 50%;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.footer-link:hover {
		color: var(--color-primary);
		padding-left: var(--spacing-5);
	}

	.footer-link:hover::before {
		opacity: 1;
	}

	.footer-bottom {
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		padding: var(--spacing-6) 0;
	}

	.footer-bottom-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--spacing-4);
	}

	.copyright p {
		color: var(--color-neutral-400);
		margin: 0;
		font-size: 0.875rem;
	}

	.footer-bottom-links {
		display: flex;
		gap: var(--spacing-6);
	}

	.footer-bottom-link {
		color: var(--color-neutral-400);
		text-decoration: none;
		font-size: 0.875rem;
		transition: color 0.3s ease;
	}

	.footer-bottom-link:hover {
		color: var(--color-primary);
	}

	@media (max-width: 768px) {
		.footer {
			padding: var(--spacing-16) 0 0;
		}

		.footer-content {
			grid-template-columns: 1fr;
			gap: var(--spacing-12);
		}

		.footer-links {
			grid-template-columns: 1fr;
			gap: var(--spacing-8);
		}

		.footer-bottom-content {
			flex-direction: column;
			text-align: center;
			gap: var(--spacing-4);
		}

		.footer-bottom-links {
			flex-wrap: wrap;
			justify-content: center;
		}

		.social-links {
			justify-content: center;
		}
	}

	@media (max-width: 480px) {
		.footer-links {
			gap: var(--spacing-6);
		}

		.link-group {
			text-align: center;
		}

		.footer-bottom-links {
			flex-direction: column;
			gap: var(--spacing-3);
		}
	}
</style>