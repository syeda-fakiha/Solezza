---
---

<section id="about" class="about section">
	<div class="container">
		<div class="about-content">
			<div class="about-text">
				<div class="section-badge">
					<span>Our Vibrant Story</span>
				</div>
				<h2 class="section-title">Bringing Color to Life Since 1998</h2>
				<p class="about-description">
					For over two decades, Solezza has been revolutionizing Pakistani footwear with bold colors and 
					vibrant designs. Our journey began with a vision to celebrate life through colorful, 
					high-quality shoes that reflect the joy and energy of Pakistani culture.
				</p>
				<p class="about-description">
					Today, we blend traditional craftsmanship with contemporary color palettes to create shoes that 
					are not just footwear, but expressions of personality and celebrations of Pakistani artistry.
				</p>
				
				<div class="about-features">
					<div class="feature">
						<div class="feature-icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"/>
							</svg>
						</div>
						<div class="feature-content">
							<h4 class="feature-title">Vibrant Materials</h4>
							<p class="feature-text">Premium leather and fabrics in stunning colors sourced from the best suppliers.</p>
						</div>
					</div>
					
					<div class="feature">
						<div class="feature-icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M12 2L13.09 4.26L16 5L13.09 5.74L12 8L10.91 5.74L8 5L10.91 4.26L12 2ZM19 9L19.74 10.26L21 11L19.74 11.74L19 13L18.26 11.74L17 11L18.26 10.26L19 9ZM19 15L19.74 16.26L21 17L19.74 17.74L19 19L18.26 17.74L17 17L18.26 16.26L19 15Z" fill="currentColor"/>
							</svg>
						</div>
						<div class="feature-content">
							<h4 class="feature-title">Colorful Craftsmanship</h4>
							<p class="feature-text">Each pair is lovingly handcrafted with vibrant colors and artistic flair.</p>
						</div>
					</div>
					
					<div class="feature">
						<div class="feature-icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</div>
						<div class="feature-content">
							<h4 class="feature-title">Bold Quality Promise</h4>
							<p class="feature-text">We guarantee vibrant colors that last and comfort that endures every step.</p>
						</div>
					</div>
				</div>
				
				<div class="about-actions">
					<button class="btn btn-primary">Learn More</button>
					<button class="btn btn-outline">Visit Workshop</button>
				</div>
			</div>
			
			<div class="about-images">
				<div class="image-grid">
					<div class="main-image">
						<img src="https://images.pexels.com/photos/2529148/pexels-photo-2529148.jpeg?auto=compress&cs=tinysrgb&w=600" 
							 alt="Colorful shoes being crafted" />
						<div class="image-badge">
							<span>25+ Years</span>
						</div>
					</div>
					<div class="secondary-images">
						<div class="secondary-image">
							<img src="https://images.pexels.com/photos/8839887/pexels-photo-8839887.jpeg?auto=compress&cs=tinysrgb&w=400" 
								 alt="Vibrant traditional shoes" />
						</div>
						<div class="secondary-image">
							<img src="https://images.pexels.com/photos/2529147/pexels-photo-2529147.jpeg?auto=compress&cs=tinysrgb&w=400" 
								 alt="Colorful shoe collection" />
						</div>
					</div>
				</div>
				
				<div class="stats-overlay">
					<div class="stat-item">
						<div class="stat-number">10,000+</div>
						<div class="stat-label">Happy Customers</div>
					</div>
					<div class="stat-item">
						<div class="stat-number">50+</div>
						<div class="stat-label">Skilled Artisans</div>
					</div>
					<div class="stat-item">
						<div class="stat-number">15+</div>
						<div class="stat-label">Awards Won</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.about {
		background: white;
	}

	.about-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-16);
		align-items: center;
	}

	.about-text {
		max-width: 600px;
	}

	.section-badge {
		display: inline-flex;
		align-items: center;
		background: rgba(139, 92, 246, 0.1);
		color: var(--color-accent);
		padding: var(--spacing-2) var(--spacing-4);
		border-radius: 50px;
		font-size: 0.875rem;
		font-weight: 600;
		margin-bottom: var(--spacing-4);
		border: 1px solid rgba(139, 92, 246, 0.2);
	}

	.section-title {
		margin-bottom: var(--spacing-6);
		color: var(--color-neutral-800);
	}

	.about-description {
		color: var(--color-neutral-600);
		font-size: 1.125rem;
		line-height: 1.75;
		margin-bottom: var(--spacing-6);
	}

	.about-features {
		margin: var(--spacing-8) 0;
	}

	.feature {
		display: flex;
		gap: var(--spacing-4);
		margin-bottom: var(--spacing-6);
	}

	.feature-icon {
		flex-shrink: 0;
		width: 48px;
		height: 48px;
		background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
		color: white;
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: var(--shadow-md);
	}

	.feature-content {
		flex: 1;
	}

	.feature-title {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--color-neutral-800);
		margin-bottom: var(--spacing-2);
	}

	.feature-text {
		color: var(--color-neutral-600);
		line-height: 1.6;
		margin: 0;
	}

	.about-actions {
		display: flex;
		gap: var(--spacing-4);
		margin-top: var(--spacing-8);
	}

	.about-images {
		position: relative;
	}

	.image-grid {
		display: grid;
		grid-template-rows: 1fr auto;
		gap: var(--spacing-4);
		height: 500px;
	}

	.main-image {
		position: relative;
		border-radius: 24px;
		overflow: hidden;
		box-shadow: var(--shadow-xl);
	}

	.main-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.main-image:hover img {
		transform: scale(1.05);
	}

	.image-badge {
		position: absolute;
		top: var(--spacing-4);
		right: var(--spacing-4);
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(10px);
		color: var(--color-primary);
		padding: var(--spacing-3) var(--spacing-4);
		border-radius: 12px;
		font-weight: 700;
		box-shadow: var(--shadow-md);
	}

	.secondary-images {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-4);
		height: 120px;
	}

	.secondary-image {
		border-radius: 16px;
		overflow: hidden;
		box-shadow: var(--shadow-md);
	}

	.secondary-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.secondary-image:hover img {
		transform: scale(1.1);
	}

	.stats-overlay {
		position: absolute;
		bottom: -20px;
		left: -20px;
		right: 20px;
		background: white;
		border-radius: 20px;
		padding: var(--spacing-6);
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-4);
		box-shadow: var(--shadow-xl);
		border: 1px solid var(--color-neutral-200);
	}

	.stat-item {
		text-align: center;
	}

	.stat-number {
		font-family: var(--font-display);
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--color-primary);
		line-height: 1;
	}

	.stat-label {
		font-size: 0.875rem;
		color: var(--color-neutral-600);
		margin-top: var(--spacing-1);
	}

	@media (max-width: 768px) {
		.about-content {
			grid-template-columns: 1fr;
			gap: var(--spacing-12);
		}

		.about-text {
			order: 2;
		}

		.about-images {
			order: 1;
		}

		.about-actions {
			flex-direction: column;
		}

		.btn {
			width: 100%;
		}

		.image-grid {
			height: 400px;
		}

		.stats-overlay {
			position: static;
			margin-top: var(--spacing-4);
			grid-template-columns: 1fr;
			text-align: left;
		}

		.stat-item {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: var(--spacing-2) 0;
			border-bottom: 1px solid var(--color-neutral-200);
		}

		.stat-item:last-child {
			border-bottom: none;
		}

		.stat-number {
			font-size: 1.25rem;
		}
	}
</style>