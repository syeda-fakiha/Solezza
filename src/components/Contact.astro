---
---

<section id="contact" class="contact section">
	<div class="container">
		<div class="section-header">
			<div class="section-badge">
				<span>Connect With Us</span>
			</div>
			<h2 class="section-title">Experience Solezza</h2>
			<p class="section-description">
				Visit our vibrant stores across Pakistan to experience our colorful collection firsthand. 
				Our passionate team will help you find the perfect pair to express your unique style.
			</p>
		</div>
		
		<div class="contact-content">
			<div class="contact-info">
				<div class="store-card">
					<div class="store-header">
						<div class="store-icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M21 10C21 17 12 23 12 23C12 23 3 17 3 10C3 7.61305 3.94821 5.32387 5.63604 3.63604C7.32387 1.94821 9.61305 1 12 1C14.3869 1 16.6761 1.94821 18.3639 3.63604C20.0518 5.32387 21 7.61305 21 10Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								<path d="M12 13C13.6569 13 15 11.6569 15 10C15 8.34315 13.6569 7 12 7C10.3431 7 9 8.34315 9 10C9 11.6569 10.3431 13 12 13Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</div>
						<h3 class="store-name">Lahore Flagship</h3>
						<span class="store-badge">Main Store</span>
					</div>
					<div class="store-details">
						<p class="store-address">MM Alam Road, Gulberg III<br>Lahore, Punjab 54000</p>
						<div class="store-contact">
							<div class="contact-item">
								<span class="contact-label">Phone:</span>
								<a href="tel:+92428765432" class="contact-value">+92 42 8765 432</a>
							</div>
							<div class="contact-item">
								<span class="contact-label">Hours:</span>
								<span class="contact-value">10 AM - 10 PM</span>
							</div>
						</div>
					</div>
				</div>
				
				<div class="store-card">
					<div class="store-header">
						<div class="store-icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M21 10C21 17 12 23 12 23C12 23 3 17 3 10C3 7.61305 3.94821 5.32387 5.63604 3.63604C7.32387 1.94821 9.61305 1 12 1C14.3869 1 16.6761 1.94821 18.3639 3.63604C20.0518 5.32387 21 7.61305 21 10Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								<path d="M12 13C13.6569 13 15 11.6569 15 10C15 8.34315 13.6569 7 12 7C10.3431 7 9 8.34315 9 10C9 11.6569 10.3431 13 12 13Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</div>
						<h3 class="store-name">Karachi Branch</h3>
					</div>
					<div class="store-details">
						<p class="store-address">Dolmen Mall, Clifton Block 4<br>Karachi, Sindh 75600</p>
						<div class="store-contact">
							<div class="contact-item">
								<span class="contact-label">Phone:</span>
								<a href="tel:+92219876543" class="contact-value">+92 21 9876 543</a>
							</div>
							<div class="contact-item">
								<span class="contact-label">Hours:</span>
								<span class="contact-value">11 AM - 11 PM</span>
							</div>
						</div>
					</div>
				</div>
				
				<div class="store-card">
					<div class="store-header">
						<div class="store-icon">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M21 10C21 17 12 23 12 23C12 23 3 17 3 10C3 7.61305 3.94821 5.32387 5.63604 3.63604C7.32387 1.94821 9.61305 1 12 1C14.3869 1 16.6761 1.94821 18.3639 3.63604C20.0518 5.32387 21 7.61305 21 10Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								<path d="M12 13C13.6569 13 15 11.6569 15 10C15 8.34315 13.6569 7 12 7C10.3431 7 9 8.34315 9 10C9 11.6569 10.3431 13 12 13Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</div>
						<h3 class="store-name">Islamabad Outlet</h3>
					</div>
					<div class="store-details">
						<p class="store-address">Centaurus Mall, F-8<br>Islamabad, ICT 44000</p>
						<div class="store-contact">
							<div class="contact-item">
								<span class="contact-label">Phone:</span>
								<a href="tel:+92519876543" class="contact-value">+92 51 9876 543</a>
							</div>
							<div class="contact-item">
								<span class="contact-label">Hours:</span>
								<span class="contact-value">10 AM - 9 PM</span>
							</div>
						</div>
					</div>
				</div>
			</div>
			
			<div class="contact-form-section">
				<div class="form-header">
					<h3>Send us a Message</h3>
					<p>Have questions about our products or need a custom order? We'd love to hear from you.</p>
				</div>
				
				<form class="contact-form">
					<div class="form-row">
						<div class="form-group">
							<label for="firstName">First Name</label>
							<input type="text" id="firstName" name="firstName" required />
						</div>
						<div class="form-group">
							<label for="lastName">Last Name</label>
							<input type="text" id="lastName" name="lastName" required />
						</div>
					</div>
					
					<div class="form-group">
						<label for="email">Email Address</label>
						<input type="email" id="email" name="email" required />
					</div>
					
					<div class="form-group">
						<label for="phone">Phone Number</label>
						<input type="tel" id="phone" name="phone" />
					</div>
					
					<div class="form-group">
						<label for="subject">Subject</label>
						<select id="subject" name="subject" required>
							<option value="">Select a subject</option>
							<option value="product-inquiry">Product Inquiry</option>
							<option value="custom-order">Custom Order</option>
							<option value="store-visit">Store Visit</option>
							<option value="complaint">Complaint</option>
							<option value="other">Other</option>
						</select>
					</div>
					
					<div class="form-group">
						<label for="message">Message</label>
						<textarea id="message" name="message" rows="5" placeholder="Tell us more about your inquiry..." required></textarea>
					</div>
					
					<button type="submit" class="btn btn-primary btn-large form-submit">
						<span>Send Message</span>
						<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M17.5 2.5L8.75 11.25M17.5 2.5L11.875 17.5L8.75 11.25M17.5 2.5L2.5 8.125L8.75 11.25" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</button>
				</form>
			</div>
		</div>
		
		<div class="newsletter-section">
			<div class="newsletter-content">
				<div class="newsletter-text">
					<h3>Stay Updated</h3>
					<p>Subscribe to our newsletter for the latest collections and exclusive offers.</p>
				</div>
				<form class="newsletter-form">
					<input type="email" placeholder="Enter your email address" required />
					<button type="submit" class="btn btn-secondary">Subscribe</button>
				</form>
			</div>
		</div>
	</div>
</section>

<style>
	.contact {
		background: linear-gradient(135deg, #FDF2F8 0%, #F0F9FF 50%, #FEF7FF 100%);
	}

	.section-header {
		text-align: center;
		max-width: 600px;
		margin: 0 auto var(--spacing-16);
	}

	.section-badge {
		display: inline-flex;
		align-items: center;
		background: rgba(225, 29, 72, 0.1);
		color: var(--color-primary);
		padding: var(--spacing-2) var(--spacing-4);
		border-radius: 50px;
		font-size: 0.875rem;
		font-weight: 600;
		margin-bottom: var(--spacing-4);
		border: 1px solid rgba(225, 29, 72, 0.2);
	}

	.section-title {
		margin-bottom: var(--spacing-4);
	}

	.section-description {
		color: var(--color-neutral-600);
		font-size: 1.125rem;
		line-height: 1.75;
		margin: 0;
	}

	.contact-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-16);
		margin-bottom: var(--spacing-20);
	}

	.contact-info {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-6);
	}

	.store-card {
		background: white;
		border-radius: 20px;
		padding: var(--spacing-6);
		box-shadow: var(--shadow-md);
		border: 1px solid var(--color-neutral-200);
		transition: all 0.3s ease;
	}

	.store-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-lg);
	}

	.store-header {
		display: flex;
		align-items: center;
		gap: var(--spacing-4);
		margin-bottom: var(--spacing-4);
		position: relative;
	}

	.store-icon {
		width: 48px;
		height: 48px;
		background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
		color: white;
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.store-name {
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--color-neutral-800);
		margin: 0;
	}

	.store-badge {
		background: var(--color-secondary);
		color: white;
		padding: var(--spacing-1) var(--spacing-2);
		border-radius: 6px;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		margin-left: auto;
	}

	.store-address {
		color: var(--color-neutral-600);
		line-height: 1.6;
		margin-bottom: var(--spacing-4);
		font-size: 1rem;
	}

	.store-contact {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}

	.contact-item {
		display: flex;
		align-items: center;
		gap: var(--spacing-2);
	}

	.contact-label {
		font-weight: 600;
		color: var(--color-neutral-700);
		min-width: 60px;
	}

	.contact-value {
		color: var(--color-neutral-600);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.contact-value:hover {
		color: var(--color-primary);
	}

	.contact-form-section {
		background: white;
		border-radius: 24px;
		padding: var(--spacing-8);
		box-shadow: var(--shadow-lg);
		border: 1px solid var(--color-neutral-200);
	}

	.form-header {
		margin-bottom: var(--spacing-8);
	}

	.form-header h3 {
		font-size: 1.5rem;
		color: var(--color-neutral-800);
		margin-bottom: var(--spacing-2);
	}

	.form-header p {
		color: var(--color-neutral-600);
		line-height: 1.6;
		margin: 0;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-6);
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-4);
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}

	.form-group label {
		font-weight: 600;
		color: var(--color-neutral-700);
		font-size: 0.875rem;
	}

	.form-group input,
	.form-group select,
	.form-group textarea {
		padding: var(--spacing-3) var(--spacing-4);
		border: 2px solid var(--color-neutral-200);
		border-radius: 12px;
		font-family: var(--font-primary);
		font-size: 1rem;
		transition: all 0.3s ease;
		background: var(--color-neutral-50);
	}

	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--color-primary);
		background: white;
		box-shadow: 0 0 0 3px rgba(4, 120, 87, 0.1);
	}

	.form-group textarea {
		resize: vertical;
		min-height: 120px;
	}

	.form-submit {
		width: 100%;
		margin-top: var(--spacing-4);
	}

	.newsletter-section {
		background: white;
		border-radius: 24px;
		padding: var(--spacing-8);
		box-shadow: var(--shadow-md);
		border: 1px solid var(--color-neutral-200);
	}

	.newsletter-content {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--spacing-8);
	}

	.newsletter-text h3 {
		font-size: 1.5rem;
		color: var(--color-neutral-800);
		margin-bottom: var(--spacing-2);
	}

	.newsletter-text p {
		color: var(--color-neutral-600);
		margin: 0;
	}

	.newsletter-form {
		display: flex;
		gap: var(--spacing-3);
		flex-shrink: 0;
	}

	.newsletter-form input {
		padding: var(--spacing-3) var(--spacing-4);
		border: 2px solid var(--color-neutral-200);
		border-radius: 12px;
		font-family: var(--font-primary);
		font-size: 1rem;
		min-width: 250px;
		background: var(--color-neutral-50);
		transition: all 0.3s ease;
	}

	.newsletter-form input:focus {
		outline: none;
		border-color: var(--color-secondary);
		background: white;
		box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.1);
	}

	@media (max-width: 768px) {
		.contact-content {
			grid-template-columns: 1fr;
			gap: var(--spacing-12);
		}

		.contact-form-section {
			padding: var(--spacing-6);
		}

		.form-row {
			grid-template-columns: 1fr;
		}

		.newsletter-content {
			flex-direction: column;
			text-align: center;
			gap: var(--spacing-6);
		}

		.newsletter-form {
			flex-direction: column;
			width: 100%;
		}

		.newsletter-form input {
			min-width: auto;
		}

		.newsletter-form button {
			width: 100%;
		}

		.store-header {
			flex-wrap: wrap;
		}

		.store-badge {
			margin-left: 0;
		}
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const contactForm = document.querySelector('.contact-form');
		const newsletterForm = document.querySelector('.newsletter-form');

		if (contactForm) {
			contactForm.addEventListener('submit', (e) => {
				e.preventDefault();
				// Here you would typically send the form data to your server
				alert('Thank you for your message! We\'ll get back to you soon.');
				contactForm.reset();
			});
		}

		if (newsletterForm) {
			newsletterForm.addEventListener('submit', (e) => {
				e.preventDefault();
				// Here you would typically send the email to your newsletter service
				alert('Thank you for subscribing to our newsletter!');
				newsletterForm.reset();
			});
		}

		// Form validation feedback
		const inputs = document.querySelectorAll('input, select, textarea');
		inputs.forEach(input => {
			input.addEventListener('blur', () => {
				if (input.hasAttribute('required') && !input.value.trim()) {
					input.style.borderColor = 'var(--color-error)';
				} else {
					input.style.borderColor = 'var(--color-neutral-200)';
				}
			});

			input.addEventListener('input', () => {
				input.style.borderColor = 'var(--color-neutral-200)';
			});
		});
	});
</script>