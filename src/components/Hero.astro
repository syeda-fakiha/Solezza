---
---

<section id="home" class="hero">
	<div class="hero-background">
		<div class="hero-pattern"></div>
	</div>
	
	<div class="container">
		<div class="hero-content">
			<div class="hero-text">
				<div class="hero-badge">
					<span class="badge-text">Bold Pakistani Style</span>
				</div>
				<h1 class="hero-title">
					Vibrant Footwear
					<span class="title-highlight">Bold & Beautiful</span>
				</h1>
				<p class="hero-description">
					Step into a world of vibrant colors and bold designs with Solezza's stunning collection. 
					Each pair celebrates Pakistani heritage with contemporary flair and eye-catching style.
				</p>
				<div class="hero-actions">
					<button class="btn btn-primary btn-large">
						<span>Shop Collection</span>
						<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M4.167 10h11.666m-5-5l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</button>
					<button class="btn btn-outline btn-large">Learn Our Story</button>
				</div>
				<div class="hero-stats">
					<div class="stat">
						<div class="stat-number">25+</div>
						<div class="stat-label">Years of Excellence</div>
					</div>
					<div class="stat">
						<div class="stat-number">10k+</div>
						<div class="stat-label">Happy Customers</div>
					</div>
					<div class="stat">
						<div class="stat-number">100%</div>
						<div class="stat-label">Handcrafted</div>
					</div>
				</div>
			</div>
			
			<div class="hero-image">
				<div class="image-container">
					<img src="https://images.pexels.com/photos/2529148/pexels-photo-2529148.jpeg?auto=compress&cs=tinysrgb&w=600" 
						 alt="Vibrant colorful shoes collection" 
						 class="hero-img" />
					<div class="image-overlay">
						<div class="overlay-content">
							<div class="feature-badge">
								<div class="feature-icon">
									<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
										<path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="currentColor"/>
									</svg>
								</div>
								<span>Premium Quality</span>
							</div>
						</div>
					</div>
				</div>
				
				<div class="floating-cards">
					<div class="floating-card card-1">
						<div class="card-icon">🇵🇰</div>
						<div class="card-text">Made in Pakistan</div>
					</div>
					<div class="floating-card card-2">
						<div class="card-icon">✨</div>
						<div class="card-text">Handcrafted</div>
					</div>
					<div class="floating-card card-3">
						<div class="card-icon">💎</div>
						<div class="card-text">Premium Leather</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding-top: var(--spacing-20);
		overflow: hidden;
		background: linear-gradient(135deg, #FDF2F8 0%, #FEF3C7 50%, #F3E8FF 100%);
	}

	.hero-background {
		position: absolute;
		inset: 0;
		z-index: -1;
	}

	.hero-pattern {
		position: absolute;
		inset: 0;
		background-image: 
			radial-gradient(circle at 25% 25%, rgba(225, 29, 72, 0.15) 0%, transparent 50%),
			radial-gradient(circle at 75% 75%, rgba(249, 115, 22, 0.15) 0%, transparent 50%),
			radial-gradient(circle at 50% 50%, rgba(139, 92, 246, 0.1) 0%, transparent 50%);
		background-size: 800px 800px;
		animation: float 20s ease-in-out infinite;
	}

	.hero-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-16);
		align-items: center;
		max-width: 1400px;
		margin: 0 auto;
	}

	.hero-text {
		max-width: 600px;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		background: rgba(225, 29, 72, 0.1);
		color: var(--color-primary);
		padding: var(--spacing-2) var(--spacing-4);
		border-radius: 50px;
		font-size: 0.875rem;
		font-weight: 600;
		margin-bottom: var(--spacing-6);
		border: 1px solid rgba(225, 29, 72, 0.2);
	}

	.badge-text {
		position: relative;
	}

	.badge-text::before {
		content: '';
		position: absolute;
		left: -12px;
		top: 50%;
		transform: translateY(-50%);
		width: 8px;
		height: 8px;
		background: var(--color-primary);
		border-radius: 50%;
		animation: pulse 2s ease-in-out infinite;
	}

	.hero-title {
		font-size: 3.5rem;
		line-height: 1.1;
		margin-bottom: var(--spacing-6);
		color: var(--color-neutral-800);
	}

	.title-highlight {
		display: block;
		background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-description {
		font-size: 1.25rem;
		line-height: 1.75;
		color: var(--color-neutral-600);
		margin-bottom: var(--spacing-8);
	}

	.hero-actions {
		display: flex;
		gap: var(--spacing-4);
		margin-bottom: var(--spacing-12);
	}

	.btn-large {
		padding: var(--spacing-4) var(--spacing-8);
		font-size: 1.125rem;
	}

	.hero-stats {
		display: flex;
		gap: var(--spacing-8);
	}

	.stat {
		text-align: center;
	}

	.stat-number {
		font-family: var(--font-display);
		font-size: 2rem;
		font-weight: 700;
		color: var(--color-primary);
		line-height: 1;
	}

	.stat-label {
		font-size: 0.875rem;
		color: var(--color-neutral-600);
		margin-top: var(--spacing-1);
	}

	.hero-image {
		position: relative;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.image-container {
		position: relative;
		width: 500px;
		height: 600px;
		border-radius: 24px;
		overflow: hidden;
		box-shadow: var(--shadow-xl);
		transform: rotate(-5deg);
		transition: transform 0.3s ease;
	}

	.image-container:hover {
		transform: rotate(0deg) scale(1.02);
	}

	.hero-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.image-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(225, 29, 72, 0.2) 0%, rgba(139, 92, 246, 0.1) 100%);
		display: flex;
		align-items: flex-end;
		padding: var(--spacing-6);
	}

	.overlay-content {
		width: 100%;
	}

	.feature-badge {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-2);
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(10px);
		color: var(--color-primary);
		padding: var(--spacing-3) var(--spacing-4);
		border-radius: 50px;
		font-weight: 600;
		box-shadow: var(--shadow-md);
	}

	.feature-icon {
		color: var(--color-accent);
	}

	.floating-cards {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.floating-card {
		position: absolute;
		display: flex;
		align-items: center;
		gap: var(--spacing-2);
		background: white;
		padding: var(--spacing-3) var(--spacing-4);
		border-radius: 16px;
		box-shadow: var(--shadow-lg);
		font-weight: 600;
		color: var(--color-neutral-700);
		border: 2px solid transparent;
		background: linear-gradient(white, white) padding-box,
					linear-gradient(135deg, var(--color-primary), var(--color-accent)) border-box;
	}

	.card-1 {
		top: 10%;
		left: -10%;
		animation: floatY 6s ease-in-out infinite;
	}

	.card-2 {
		top: 60%;
		right: -5%;
		animation: floatY 6s ease-in-out infinite 2s;
	}

	.card-3 {
		bottom: 20%;
		left: -15%;
		animation: floatY 6s ease-in-out infinite 4s;
	}

	.card-icon {
		font-size: 1.5rem;
	}

	@media (max-width: 768px) {
		.hero {
			min-height: 100vh;
			padding-top: var(--spacing-16);
		}

		.hero-content {
			grid-template-columns: 1fr;
			gap: var(--spacing-12);
			text-align: center;
		}

		.hero-title {
			font-size: 2.5rem;
		}

		.hero-description {
			font-size: 1.125rem;
		}

		.hero-actions {
			flex-direction: column;
			align-items: center;
		}

		.btn-large {
			width: 100%;
			max-width: 300px;
		}

		.hero-stats {
			justify-content: center;
		}

		.image-container {
			width: 350px;
			height: 400px;
		}

		.floating-cards {
			display: none;
		}
	}

	@keyframes float {
		0%, 100% { transform: translateY(0px) rotate(0deg); }
		50% { transform: translateY(-20px) rotate(1deg); }
	}

	@keyframes floatY {
		0%, 100% { transform: translateY(0px); }
		50% { transform: translateY(-15px); }
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.5; }
	}
</style>